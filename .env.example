# Google OAuth2 — Google Cloud Console > APIs & Services > Credentials
# Teste LOCAL: não precisa hospedar. Use http://localhost abaixo.
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
# IMPORTANTE: redirect aponta para o BACK-END (3001), não para o Vite (5173)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback

# URL do front-end (redirecionamento pós-login Google)
FRONTEND_URL=http://localhost:5173

# Porta do servidor Express
PORT=3001

# PostgreSQL — crie o banco antes: createdb pep_emr
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pep_emr
