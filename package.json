{
  "name": "pep-emr",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/server.js",
    "dev:client": "npm run dev --prefix client",
    "install:all": "npm install && npm install --prefix client",
    "check:google": "node scripts/check-google-env.js",
    "db:migrate": "node server/scripts/migrate.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
